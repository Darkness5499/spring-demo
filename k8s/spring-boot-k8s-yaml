apiVersion: apps/v1
kind: Deployment
metadata:
  name: springboot-app
  namespace: dev
spec:
  replicas: 2
  selector:
    matchLabels:
      app: springboot
  template:
    metadata:
      labels:
        app: springboot
    spec:
      containers:
      - name: springboot-container

        image: diepvn1/springboot-app:latest
        ports:
        - containerPort: 8081
---
apiVersion: v1
kind: Service
metadata:
  name: springboot-service
  namespace: dev
spec:
  selector:
    app: springboot
  ports:
  - protocol: TCP
    port: 8081
    targetPort: 8081
  type: ClusterIP